# App
APP_ENV=development
PORT=3000
APP_URL=http://localhost:3000
DATABASE_PATH=./data/sms.db

# ServiceM8
SERVICEM8_APP_ID=
SERVICEM8_APP_SECRET=
SERVICEM8_REDIRECT_URI=http://localhost:3000/oauth/callback

# Yeastar (router static IP + port-forward)
YEASTAR_HOST=203.0.113.50
YEASTAR_HTTP_PORT=8080
YEASTAR_API_PORT=5038
YEASTAR_USERNAME=apiuser
YEASTAR_PASSWORD=apiuser
YEASTAR_SIM_PORT=1
YEASTAR_USE_HTTPS=false
YEASTAR_WEBCGI_PATH=/cgi/WebCGI
YEASTAR_ACCOUNT_QUERY_KEY=1500101=account
YEASTAR_DEST_PARAM=number
YEASTAR_SEND_ENABLED=false
YEASTAR_RECEIVE_ENABLED=true

# UAT safety (optional — remove when going live)
# SMS_TEST_MOBILE=0412345678
# SMS_TEST_JOB_UUID=your-job-uuid-here
